{
  "name": "yiranubari/profile-intelligence",
  "description": "Profile Intelligence Service API",
  "license": "MIT",
  "type": "project",
  "require": {
    "php": "^8.2",
    "firebase/php-jwt": "^7.0",
    "guzzlehttp/guzzle": "^7.10",
    "monolog/monolog": "^3.8",
    "php-di/php-di": "^7.1",
    "predis/predis": "^3.4",
    "respect/validation": "^2.3",
    "slim/psr7": "^1.7",
    "slim/slim": "^4.14",
    "symfony/uid": "^7.2",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/",
      "App\\Database\\": "database/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "start": "php -S 0.0.0.0:8080 -t public",
    "test": "phpunit"
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  }
}
